---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h4><strong>Related works</strong></h4>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  <p style="font-size: 0.8rem;"><i>Disclaimer: The contents provided on this page are for personal, academic, and non-commercial use only. Copyrights and all other rights are maintained by the respective authors or publishers. These materials may not be reposted without the explicit permission of the copyright holder.</i></p>

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
